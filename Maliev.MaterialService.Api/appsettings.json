{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.Watch": "Warning",
      "System": "Warning"
    }
  },
  "Authentication": {
    "Oidc": {
      "Authority": "https://iam.maliev.com/realms/maliev",
      "ClientId": "material-service",
      "CallbackPath": "/signin-oidc",
      "RequireHttpsMetadata": true
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*",
  "Services": {
    "SupplierService": {
      "BaseUrl": "http://maliev-supplierservice-api"
    },
    "IAMService": {
      "BaseUrl": "http://maliev-iamservice-api"
    }
  }
}
